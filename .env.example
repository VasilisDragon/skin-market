# Postgres container credentials (read by docker-compose).
POSTGRES_USER=skinmarket
POSTGRES_PASSWORD=changeme_in_dev
POSTGRES_DB=skinmarket

# Application connection URL. Use 'localhost' when running the app on the host;
# use 'postgres' (the compose service name) when the app runs inside the same
# docker-compose network in later phases.
DATABASE_URL=postgresql+psycopg://skinmarket:changeme_in_dev@localhost:5432/skinmarket

# Logging
LOG_LEVEL=INFO

# Single static bearer token for the read API (Phase 6.6, ADR 014 §10).
# Generate once via `openssl rand -hex 32`. NOT user-tier auth — this is
# the machine boundary between the api container and whatever calls it
# (Hermes bot, operator curl). To rotate: replace, then
# `docker compose up -d api` + restart the bot's environment.
SKIN_MARKET_API_TOKEN=run_openssl_rand_hex_32_and_paste_the_output_here

# Ollama (analytics narrative job). Override OLLAMA_MODEL to the 27b
# model on the Spark for higher-quality prose; see ADR 011.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gpt-oss:20b
