# skin-market — environment variables.
#
# Copy this file to .env and fill in real values before
# `docker compose up -d`. Lines below grouped by which service reads them.
# See docs/operations.md for the operational story; ADRs 011 / 014 §10 /
# 016 carry the design rationale.

# ─── Postgres ───────────────────────────────────────────────────────────────
# Read by the postgres container on FIRST init of its data volume.
# Changing these after init does NOT update the running postgres — see
# docs/operations.md §"Postgres password rotation footgun".
POSTGRES_USER=skinmarket
POSTGRES_PASSWORD=changeme_in_dev
POSTGRES_DB=skinmarket

# Host-side DATABASE_URL — used by Alembic migrations + ad-hoc scripts
# run with `uv run` from the host (NOT by compose-internal services;
# those build their own URL from POSTGRES_* using the `postgres` service
# hostname). Keep this in sync with POSTGRES_* above if you change them.
DATABASE_URL=postgresql+psycopg://skinmarket:changeme_in_dev@localhost:5432/skinmarket

# ─── Logging ────────────────────────────────────────────────────────────────
# Python stdlib levels: DEBUG / INFO / WARNING / ERROR / CRITICAL.
# Applies to every service's Python process. Log rotation (size + file
# count) is configured at the Docker daemon layer in docker-compose.yml,
# not here.
LOG_LEVEL=INFO

# ─── Read API auth (Phase 6.6 / 7b — ADR 014 §10) ───────────────────────────
# SKIN_MARKET_API_TOKEN — single-token convenience alias. Generate via
#   `openssl rand -hex 32`. Required at api startup (auth fails closed
#   if unset). The bot reads the same value to authenticate to the api.
# SKIN_MARKET_API_TOKENS — plural, comma-separated. Accepted set unions
#   with the singular alias above. Empty in single-consumer
#   deployments; populate during a graceful rotation cutover so the bot
#   never sees a 401 (see docs/operations.md §"API bearer token"
#   rotation recipe).
SKIN_MARKET_API_TOKEN=run_openssl_rand_hex_32_and_paste_the_output_here
SKIN_MARKET_API_TOKENS=

# ─── Discord bot (Phase 7c — ADR 016) ───────────────────────────────────────
# DISCORD_BOT_TOKEN — from the Discord application's Bot page at
#   https://discord.com/developers/applications. Treat as a secret;
#   leaked tokens let anyone impersonate the bot. The MESSAGE_CONTENT
#   privileged intent must also be enabled in the dev portal.
# DISCORD_ALLOWED_USER_IDS — comma-separated decimal Discord user IDs.
#   Only these users get replies. Empty rejects everyone with a
#   config-error message (fail closed; default-deny). Find your user
#   ID: Discord Settings → Advanced → Developer Mode, then right-click
#   your username → Copy User ID.
DISCORD_BOT_TOKEN=paste_discord_bot_token_here
DISCORD_ALLOWED_USER_IDS=123456789012345678,987654321098765432
PRICE_ALERT_POLL_SECONDS=60
PRICE_ALERT_BATCH_LIMIT=100

# ─── DeepSeek (analytics narrative + bot tool routing) ──────────────────────
# DEEPSEEK_API_KEY — bearer token for https://api.deepseek.com.
#   Required by both the bot and analytics services; if unset, the
#   LLM call fails fast without making a request.
# DEEPSEEK_MODEL — defaults to deepseek-v4-flash in non-thinking mode.
#   The bot and narrative job both use this model. See ADR 026 for
#   pricing and rationale.
# LLM_USAGE_LOG_FULL_PROMPT — off by default. Set to true only in
#   development if you explicitly want llm_usage_log.full_prompt
#   populated; hash + bounded preview are logged either way.
# DEEPSEEK_DAILY_COST_LIMIT_USD — optional global 24h rolling bot spend
#   cap. Empty/0 disables it.
# DEEPSEEK_DAILY_USER_COST_LIMIT_USD — optional per-Discord-user 24h
#   rolling spend cap. Empty/0 disables it.
DEEPSEEK_API_KEY=paste_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_USAGE_LOG_FULL_PROMPT=false
DEEPSEEK_DAILY_COST_LIMIT_USD=0
DEEPSEEK_DAILY_USER_COST_LIMIT_USD=0

# ─── Pricempire bulk ingest (Phase 2a — ADR 018/019) ─────────────────────────
# PRICEMPIRE_API_KEY — Developer-tier bearer token for
#   https://api.pricempire.com/v4/paid/items/prices. Sign up at
#   pricempire.com → API → generate a key. Required by the collector
#   service; if unset, the Pricempire cycle logs an ERROR at startup
#   and runs no HTTP calls (fail-fast — see ADR 019 §6). The 15-min
#   cycle interval uses ~2,880 calls/month, well under the Developer
#   tier's 10,000-call ceiling. ADR 018 §"Context" carries the budget
#   math.
PRICEMPIRE_API_KEY=paste_pricempire_dev_key_here

# ─── Pattern-aware drift detection (Phase 2b — ADR 022) ──────────────────────
# DRIFT_DETECTION_ENABLED — feature flag for analytics/scheduler.py's
#   30-minute drift-detection cycle. The detector reads each deep-tier
#   item's curated and Pricempire prices, decides a verdict via the
#   pattern-sensitivity classifier (ADR 021), and writes drift_verdict
#   rows to the insights table.
#
#   Accepted truthy values (case-insensitive): "true", "1", "yes", "on".
#   Anything else (unset, empty, "false", "0", etc.) — cycle no-ops.
#
#   Phase 2b Step 7.2 flipped this to "true" on the live host. Defaulted
#   to "false" in this example file so a fresh-deploy operator who
#   hasn't yet validated the Step 7 re-seed doesn't accidentally turn
#   the detector on before the deep-tier composition is correct.
DRIFT_DETECTION_ENABLED=false
