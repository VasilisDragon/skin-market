# Runtime caches/exports go under data/cache/ or data/exports/, both
# excluded. Source-of-truth files (e.g. data/watchlist.yaml) stay tracked.
data/cache/
data/exports/

# Operator scratch directory. Holds ephemeral working notes, draft
# proposals, and anything that isn't a permanent architectural record.
# Architectural memory lives in docs/adr/, docs/*.md, and the ADR
# catalog in PROJECT_OVERVIEW.md.
notes/

# never commit env backups or variants
.env.*
.env.bak
